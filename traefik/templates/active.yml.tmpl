http:
  routers:
    api-verixa:
      rule: "PathPrefix(`/`)"
      entryPoints:
        - verixa
      service: api-verixa-weighted

    api-lgpay:
      rule: "PathPrefix(`/`)"
      entryPoints:
        - lgpay
      service: api-lgpay-weighted

    api-sandbox:
      rule: "PathPrefix(`/`)"
      entryPoints:
        - sandbox
      service: api-sandbox-weighted

  services:
    # ── Verixa weighted (active color) ──────────────────────────────────────
    api-verixa-weighted:
      weighted:
        services:
          - name: api-verixa-__VERIXA_ACTIVE_COLOR__
            weight: 100

    api-verixa-blue:
      loadBalancer:
        passHostHeader: true
        healthCheck:
          path: /readyz
          interval: 10s
          timeout: 3s
        servers:
          - url: "http://api-verixa-blue:__VERIXA_PORT__"

    api-verixa-green:
      loadBalancer:
        passHostHeader: true
        healthCheck:
          path: /readyz
          interval: 10s
          timeout: 3s
        servers:
          - url: "http://api-verixa-green:__VERIXA_PORT__"

    # ── Lgpay weighted (active color) ───────────────────────────────────────
    api-lgpay-weighted:
      weighted:
        services:
          - name: api-lgpay-__LGPAY_ACTIVE_COLOR__
            weight: 100

    api-lgpay-blue:
      loadBalancer:
        passHostHeader: true
        healthCheck:
          path: /readyz
          interval: 10s
          timeout: 3s
        servers:
          - url: "http://api-lgpay-blue:__LGPAY_PORT__"

    api-lgpay-green:
      loadBalancer:
        passHostHeader: true
        healthCheck:
          path: /readyz
          interval: 10s
          timeout: 3s
        servers:
          - url: "http://api-lgpay-green:__LGPAY_PORT__"

    # ── Sandbox weighted (active color) ─────────────────────────────────────
    api-sandbox-weighted:
      weighted:
        services:
          - name: api-sandbox-__SANDBOX_ACTIVE_COLOR__
            weight: 100

    api-sandbox-blue:
      loadBalancer:
        passHostHeader: true
        healthCheck:
          path: /readyz
          interval: 10s
          timeout: 3s
        servers:
          - url: "http://api-sandbox-blue:__SANDBOX_PORT__"

    api-sandbox-green:
      loadBalancer:
        passHostHeader: true
        healthCheck:
          path: /readyz
          interval: 10s
          timeout: 3s
        servers:
          - url: "http://api-sandbox-green:__SANDBOX_PORT__"
