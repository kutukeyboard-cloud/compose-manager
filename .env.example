# Copy to .env and replace placeholders for your environment. Do not commit .env.
COMPOSE_PROJECT_NAME=service-webhook-bg

# Traefik public entrypoints. App containers do not publish host ports.
VERIXA_TRAEFIK_PORT=8900
LGPAY_TRAEFIK_PORT=8902
TRAEFIK_DASHBOARD_PORT=8080

# Shared Docker network used to reach backing services such as MySQL/Redis/Laravel.
# Create it first if external: docker network create shared
SHARED_NETWORK_NAME=shared

# Local build workflow
SERVICE_WEBHOOK_PATH=../verixa-code/service-webhook

# Registry workflow
SERVICE_WEBHOOK_IMAGE=registry.example.com/namespace/service-webhook
SERVICE_WEBHOOK_VERSION=replace-with-version

# ── Verixa brand ────────────────────────────────────────────────────────────
VERIXA_PORT=8900
VERIXA_DB_NAME=verixa_prod
VERIXA_INTERNAL_TRANSFER_BASE_URL=http://verixa-org-web:8000
VERIXA_BLUE_INTERNAL_TRANSFER_BASE_URL=http://verixa-org-web-blue:8000
VERIXA_GREEN_INTERNAL_TRANSFER_BASE_URL=http://verixa-org-web:8000

# ── Lgpay brand ─────────────────────────────────────────────────────────────
LGPAY_PORT=8902
LGPAY_DB_NAME=lgpay_prod
LGPAY_INTERNAL_TRANSFER_BASE_URL=http://lgpay-web:8000
LGPAY_BLUE_INTERNAL_TRANSFER_BASE_URL=http://lgpay-web-blue:8000
LGPAY_GREEN_INTERNAL_TRANSFER_BASE_URL=http://lgpay-web:8000
