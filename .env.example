# Copy to .env and replace placeholders for your environment. Do not commit .env.
COMPOSE_PROJECT_NAME=service-webhook-bg

# Traefik public entrypoint. App containers do not publish host ports.
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8080
SERVICE_WEBHOOK_HOST=webhook.example.test

# Shared Docker network used to reach backing services such as MySQL/Redis/Laravel.
# Create it first if external: docker network create shared
SHARED_NETWORK_NAME=shared

# Local build workflow
SERVICE_WEBHOOK_PATH=../verixa-code/service-webhook

# Registry workflow
SERVICE_WEBHOOK_IMAGE=registry.example.com/namespace/service-webhook
SERVICE_WEBHOOK_VERSION=replace-with-version

# Runtime placeholders for service-webhook. Replace in .env only.
APP_ENV=production
APP_NAME=Verixa
APP_PORT=8080
DB_HOST=mysql
DB_PORT=3306
DB_USER=replace-with-db-user
DB_PASS=replace-with-db-password
DB_NAME=replace-with-db-name
DB_CHARSET=utf8mb4
REDIS_ADDR=redis:6379
REDIS_PASSWORD=replace-with-redis-password-or-empty
REDIS_DB=0
LOG_LEVEL=1
REQUEST_TIMEOUT_SECONDS=15
INTERNAL_TRANSFER_BASE_URL=http://verixa-org-web:8000
INTERNAL_TRANSFER_PATH=/api/v1/internal-transfer
SETTLEMENT_T0_INTERVAL=10m
SETTLEMENT_T1_CRON_TIME=16:00
SETTLEMENT_CUTOFF_TIME=23:30
SETTLEMENT_LOCK_TTL_SECONDS=300
SETTLEMENT_MAX_RETRIES=3
SETTLEMENT_PER_CHANNEL_ENABLED=true
TIMEZONE=Asia/Shanghai
CRON_TZ=Asia/Shanghai
PAYOUT_DEBUG_FULL_LOG=true
CACHE_INVALIDATION_ENABLED=true
